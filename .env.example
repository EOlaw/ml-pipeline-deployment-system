# ─── Copy this file to .env and fill in real values ─────────────────────────
# NEVER commit .env to version control

# ─── API Settings ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5000
FLASK_DEBUG=false
MODEL_VERSION=v1

# ─── Model Training ──────────────────────────────────────────────────────────
RANDOM_STATE=42
TEST_SIZE=0.2
CV_FOLDS=5
N_JOBS=-1
SCORING_METRIC=f1

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── AWS (Production) ────────────────────────────────────────────────────────
# These are kept out of code and loaded only at runtime via IAM roles or Secrets Manager
AWS_REGION=us-east-1
S3_BUCKET=ml-pipeline-models
S3_MODEL_KEY=models/model_v1.pkl

# ─── RDS (PostgreSQL — Production dataset store) ─────────────────────────────
RDS_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=mldb
RDS_USER=mluser
# RDS_PASSWORD — load from AWS Secrets Manager, not here

# ─── CloudWatch ──────────────────────────────────────────────────────────────
CLOUDWATCH_LOG_GROUP=/ml-pipeline/predictions
